<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="hud-container" style="flex-grow: 1; flex-direction: column; justify-content: flex-start; align-items: flex-start; padding-left: 20px; padding-right: 20px; padding-top: 20px; padding-bottom: 20px;">
        <ui:VisualElement name="top-bar" style="flex-direction: row; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 10px;">
            <ui:VisualElement name="health-container" style="min-width: 200px; min-height: 30px;" />
            <ui:VisualElement name="mana-container" style="min-width: 200px; min-height: 30px;" />
        </ui:VisualElement>
        <ui:VisualElement name="bottom-bar" style="flex-direction: row; justify-content: center; align-items: flex-end; width: 100%; flex-grow: 1;">
            <ui:VisualElement name="action-bar" style="flex-direction: row; justify-content: center; align-items: center;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
